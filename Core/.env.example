APP_NAME=neuro_core
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080

# LLM backend
LLM_PROVIDER=ollama

# OpenAI-compatible endpoint (used when LLM_PROVIDER=openai)
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-GPTQ-Int4
LLM_API_KEY=EMPTY
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_STREAM=true
LLM_MAX_CONTEXT=8192
LLM_MAX_OUTPUT=512
ASSISTANT_STREAM_CHUNK_CHARS=12
ASSISTANT_STREAM_INTERVAL_MS=25

# Native Ollama endpoint (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_SEC=60
OLLAMA_MODELS_DIR=C:\Users\AzusaFish\.ollama\models

# Token budget policy
CONTEXT_RESERVED_FOR_RESPONSE=700
CONTEXT_RESERVED_FOR_TOOLS=800

# TTS / STT / OCR / Vision service endpoint
TTS_BASE_URL=http://127.0.0.1:9880
TTS_PROVIDER=kokoro
TTS_PROFILE_PATH=./configs/tts_profiles.yaml
TTS_DEFAULT_SPEAKER=atri
TTS_STREAMING_MODE=false

# GPT-SoVITS endpoint (legacy compatibility)
GPT_SOVITS_BASE_URL=http://127.0.0.1:9880

# Kokoro endpoint (default)
KOKORO_BASE_URL=http://127.0.0.1:9880
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_sky
KOKORO_LANG=en-us
KOKORO_RESPONSE_FORMAT=wav
KOKORO_SPEED=1.0
KOKORO_MODEL_PATH=./assets/kokoro/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=./assets/kokoro/voices-v1.0.bin
KOKORO_CHUNK_CHARS=180

STT_BASE_URL=http://127.0.0.1:9000
STT_PROVIDER=http
STT_CONTROL_WS_URL=ws://127.0.0.1:8011
STT_DATA_WS_URL=ws://127.0.0.1:8012
OCR_BASE_URL=http://127.0.0.1:9001
VISION_BASE_URL=http://127.0.0.1:9002

# Local repositories (for dependency health checks)
GPT_SOVITS_REPO=D:\AzusaFish\Codes\Development\AI\GPT-SoVITS-main\GPT-SoVITS-main
KOKORO_REPO=D:\AzusaFish\Codes\Development\AI\Core
REALTIMESTT_REPO=D:\AzusaFish\Codes\Development\AI\RealtimeSTT-master\RealtimeSTT-master
REFERENCE_CORE_REPO=D:\AzusaFish\Codes\Development\Project-Avis\Z\reference-core-main

# WeChat bridge (you can replace with your own process)
WECHAT_BRIDGE_URL=http://127.0.0.1:9010

# Slay the Spire bridge (Communication Mod adapter)
STS_BRIDGE_URL=http://127.0.0.1:9011

# Google search function backend (self-hosted wrapper)
SEARCH_API_URL=http://127.0.0.1:9012/search

# Memory
SQLITE_PATH=./data/memory.db
CHROMA_PATH=./data/chroma
PERSONA_COLLECTION=persona_lines
MEMORY_COLLECTION=long_term_memory

# Runtime
AGENT_TICK_INTERVAL_SEC=0.2
PROACTIVE_SILENCE_SEC=300

# Optional bridge runtime (for bridges/realtimestt_http_bridge.py)
STT_BRIDGE_HOST=127.0.0.1
STT_BRIDGE_PORT=9000
