# Optional local overrides only.
# Primary configuration is now at ../config.yaml
# Copy to .env when you need per-machine overrides.
#
# Example:
# APP_PORT=8081
# LLM_API_KEY=your-secret
# WECHAT_BRIDGE_PROVIDER=itchat
# ITCHAT_ENABLE_CMD_QR=2
# WECHAT_BRIDGE_PROVIDER=gewechat
# GEWECHAT_BASE_URL=http://127.0.0.1:2531/v2/api
# GEWECHAT_TOKEN=your_gewechat_token
# GEWECHAT_APP_ID=your_app_id
